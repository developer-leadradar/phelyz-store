{
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/(.*\\.php(?:\\?.*)?)",
      "dest": "/$1"
    },
    {
      "src": "/$",
      "dest": "/index.php"
    }
  ]
}
